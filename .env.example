# ── Environment variables for the Audio Explorers project ────────────────
# Copy this file to .env and fill in the values.
# .env is git-ignored and should NEVER be committed.

# Project root (auto-detected in most scripts; override if needed)
# PROJECT_ROOT=/home/you/Audio_explorers_software

# Whisper model cache directory (leave blank to use default ~/.cache)
# WHISPER_CACHE_DIR=

# HuggingFace / SpeechBrain cache
# HF_HOME=
# SPEECHBRAIN_CACHE=

# Optional: GPU device index
# CUDA_VISIBLE_DEVICES=0
